# deAPI Configuration (Primary)
DEAPI_API_KEY=your_deapi_api_key_here
DEAPI_BASE_URL=https://api.deapi.ai

# Legacy Geminigen (optional, for backwards compatibility)
GEMINIGEN_API_KEY=
GEMINIGEN_API_BASE_URL=https://api.geminigen.ai/uapi/v1

# Webhook Configuration
USE_WEBHOOK=false
WEBHOOK_URL=http://localhost:8000/webhook/deapi
PUBLIC_KEY_PATH=../uapi_public_key.pem
DATABASE_URL=sqlite:///./videlo.db

# CORS Configuration (comma-separated origins for production)
# Example: ALLOWED_ORIGINS=https://your-frontend.vercel.app,https://your-frontend.onrender.com
ALLOWED_ORIGINS=*
